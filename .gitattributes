# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf
*.sql text eol=lf
*.ini text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.gif binary
*.woff binary
*.woff2 binary
