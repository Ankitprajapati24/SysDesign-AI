# ============================================================
# frontend/.env.example — SysDesign-AI Frontend Configuration
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in all values below
#   3. NEVER commit .env.local to Git!
#
# NOTE: React environment variables MUST start with REACT_APP_
#       They are bundled at BUILD TIME (not runtime).
#       Do NOT put secret API keys here — this is public!
# ============================================================

# ─── BACKEND API URL ──────────────────────────────────────────
# Development: Leave empty (auto-detects localhost:8000 via config.js)
# Production: Set to your Render/Railway backend URL
# REACT_APP_API_BASE_URL=https://your-backend.onrender.com
